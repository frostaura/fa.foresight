# fa.foresight — Environment Variables
# Copy to .env and fill in values before running docker compose.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=foresight
POSTGRES_USER=foresight
POSTGRES_PASSWORD=foresight_dev_pw
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full connection string — must match POSTGRES_* values above.
# The backend DI reads this under the key "Postgres".
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=foresight;Username=foresight;Password=foresight_dev_pw

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
CORS_ALLOWED_ORIGINS=http://localhost:8088

# ---------------------------------------------------------------------------
# Key vault — EOA private key for Polymarket CLOB V2 signing.
# Leave empty in dev; required for live trading.
# SECURITY: treat this as a secret; never commit a real key.
# ---------------------------------------------------------------------------
KeyVault__PrivateKey=
# signatureType: 0 EOA (default), 1 POLY_PROXY, 2 POLY_GNOSIS_SAFE.
KeyVault__SignatureType=0
# Funder/maker address — defaults to the signer EOA when empty (proxy/deposit wallet switch).
KeyVault__Funder=

# ---------------------------------------------------------------------------
# Polymarket CLOB V2
# ---------------------------------------------------------------------------
# Set to true only after the supervised $1 validation order passes.
Polymarket__LiveTrading=false
# L2 API credentials (derived from your EOA via the Polymarket CLOB API).
Polymarket__ApiKey=
Polymarket__ApiSecret=
Polymarket__ApiPassphrase=
Polymarket__WalletAddress=

# ---------------------------------------------------------------------------
# Notifications (thin outbound channel — optional). Leave tokens empty to fall
# back to the log channel. Lists bind by index, e.g. TelegramBot__AllowedChatIds__0.
# ---------------------------------------------------------------------------
TelegramBot__Token=
TelegramBot__AllowedChatIds__0=
DiscordBot__Token=
DiscordBot__AllowedChannelIds__0=

# ---------------------------------------------------------------------------
# Sandbox sidecar
# ---------------------------------------------------------------------------
Sandbox__BaseUrl=http://sandbox:8000
SANDBOX_ENV=production

# ---------------------------------------------------------------------------
# Gateway (nginx reverse proxy)
# ---------------------------------------------------------------------------
GATEWAY_PORT=8088
NGINX_BACKEND_PORT=5000
NGINX_FRONTEND_PORT=80
NGINX_CLIENT_MAX_BODY_SIZE=10m

# ---------------------------------------------------------------------------
# Docker Hub (CI only — not needed for local dev)
# ---------------------------------------------------------------------------
DOCKERHUB_USERNAME=

# ---------------------------------------------------------------------------
# Portainer deploy (CI only)
# After CI publishes the latest images, the deploy-portainer job calls
# Portainer's API to re-pull and redeploy the stack.
# ---------------------------------------------------------------------------
PORTAINER_URL=
PORTAINER_TOKEN=
PORTAINER_ENDPOINT_ID=
PORTAINER_STACK_ID=
